{
  "type": "part",
  "input": [
    {
      "id": "$countertop-width",
      "type": "number",
      "default": 1400,
      "min": 500,
      "max": 4000
    },
    {
      "id": "$countertop-depth",
      "type": "number",
      "default": 600,
      "min": 200,
      "max": 2000
    }
  ],
  "expressions": [],
  "output": {
    "shapekeys": [
      {
        "id": "$shape-width",
        "type": "shapekey",
        "inputs": "$countertop-width",
        "conversion": "($countertop-width - 1000) / 3000"
      },
      {
        "id": "$shape-depth",
        "type": "shapekey",
        "inputs": "$countertop-depth",
        "conversion": "($countertop-depth - 500) / 1500"
      }
    ],
    "attachmentPoints": [],
    "values": []
  }
}
